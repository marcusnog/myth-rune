# Copy to .env and adjust. Never commit real secrets.
#
# Local dev (Node on host): start Postgres + Redis, then migrate + dev:
#   docker compose up postgres redis -d
#   npm run migrate && npm run dev
#
# Docker-all-in-one (entire backend in containers):
#   docker compose up --build
#   Only port 3000 is published (gateway). Login/world/combat stay on the Docker network — no clash with local npm dev on 3001–3003.
#   API: http://localhost:3000  (gateway proxies /auth, /combat, /ws)
#   Set JWT_SECRET in .env before production builds.
#   Health: npm run check:health   (use npm run check:health:all when running services on host)
#
# Godot 4 client: open folder client/ in Godot — see client/README.txt

POSTGRES_USER=myth
POSTGRES_PASSWORD=myth_dev
POSTGRES_DB=myth_rune
POSTGRES_PORT=5432

# Used by Node services (single URL for app + migrations)
DATABASE_URL=postgresql://myth:myth_dev@localhost:5432/myth_rune

# Host port only when you run Redis from compose and map a port (see docker-compose).
# Full stack in Docker does not publish Redis to the host — use: docker compose exec redis redis-cli
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_SECONDS=3600

LOGIN_SERVER_PORT=3001
GATEWAY_PORT=3000
WORLD_SERVER_PORT=3002
COMBAT_SERVER_PORT=3003

# Internal URLs for gateway (Docker network hostnames if running in compose)
LOGIN_SERVER_URL=http://127.0.0.1:3001
WORLD_SERVER_URL=http://127.0.0.1:3002
COMBAT_SERVER_URL=http://127.0.0.1:3003

NODE_ENV=development
